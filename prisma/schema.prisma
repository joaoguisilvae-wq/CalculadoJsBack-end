// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Get a free hosted Postgres database in seconds: `npx create-db`

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model Operation {
  id        Int     @id @default(autoincrement())
  previousValue Float
  currentValue  Float
  symbol        String  
  result        Float
  createdAt DateTime @default(now())
}

model ConversionType {
  id        Int    @id @default(autoincrement())
  name      String @unique // "comprimento", "peso", "temperatura"
  label     String
  units     ConversionUnit[]
}

model ConversionUnit {
  id              Int              @id @default(autoincrement())
  conversionTypeId Int
  conversionType  ConversionType   @relation(fields: [conversionTypeId], references: [id])
  unit            String           // "km", "m", "mm", etc
  label           String           // "Quilômetro", "Metro"
  rate            Float            // Taxa de conversão para unidade base
  createdAt       DateTime         @default(now())
}

model ExchangeRate {
  id        Int     @id @default(autoincrement())
  currency  String  @unique // "USD", "BRL", "EUR"
  rate      Float   // Taxa em relação a uma moeda base (USD)
  label     String
  updatedAt DateTime @updatedAt
}